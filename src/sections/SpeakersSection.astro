---

<Container>
  <section class="py-16 lg:px-4">
    <div class="text-center mb-16 animate-fade-in-up">
      <h2 class="text-4xl md:text-5xl font-bold mb-6">
        <span class="text-white/80">Nuestros </span>
        <span class="text-gradient">Ponentes</span>
      </h2>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-3">
      {
        speakers.map((speaker) => (
          <div
            class:list={[
              "speaker-card rounded-2xl overflow-hidden",
              { "speaker-blur": showBlur },
              { "speaker-clear": !showBlur },
            ]}
          >
            <div class="flex flex-col">
              <div class="flex-shrink-0 space-y-3 py-3">
                <div class="speaker-image w-full h-full flex items-center justify-center">
                  <img
                    src={speaker.image || "/placeholder.svg"}
                    alt={speaker.name}
                    class="w-24 h-24 lg:w-32 lg:h-32 rounded-full object-cover shadow-lg"
                  />
                </div>
                <div class="flex gap-2 justify-center items-center text-white/80">
                  {speaker.linkedin && (
                    <a href={speaker.linkedin} target="_blank">
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="24"
                        height="24"
                        viewBox="0 0 24 24"
                      >
                        <path
                          fill="currentColor"
                          d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2zm-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93zM6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37z"
                        />
                      </svg>
                    </a>
                  )}
                  {speaker.website && (
                    <a href={speaker.website} target="_blank">
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="24"
                        height="24"
                        viewBox="0 0 48 48"
                      >
                        <g fill="none" stroke="currentColor" stroke-width="3">
                          <path
                            stroke-linejoin="round"
                            d="M3 24a21 21 0 1 0 42 0a21 21 0 1 0-42 0"
                          />
                          <path
                            stroke-linejoin="round"
                            d="M15 24a9 21 0 1 1 18 0a9 21 0 1 1-18 0"
                          />
                          <path
                            stroke-linecap="round"
                            d="M4.5 31h39m-39-14h39"
                          />
                        </g>
                      </svg>
                    </a>
                  )}
                  {speaker.tiktok && (
                    <a href={speaker.tiktok} target="_blank">
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="24"
                        height="24"
                        viewBox="0 0 24 24"
                      >
                        <path
                          fill="currentColor"
                          d="M16 1h-3.5v15.5c0 1.5-1.5 3-3 3s-3-.5-3-3c0-2 1.899-3.339 3.5-3V10c-6.12 0-7 5-7 6.5S3.977 23 9.5 23c4.522 0 6.5-3.5 6.5-6V8c1.146 1.018 2.922 1.357 5 1.5V6c-3.017 0-5-2.654-5-5"
                        />
                      </svg>
                    </a>
                  )}

                  {speaker.youtube && (
                    <a href={speaker.youtube} target="_blank">
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="24"
                        height="24"
                        viewBox="0 0 24 24"
                      >
                        <path
                          fill="currentColor"
                          d="m10 15l5.19-3L10 9zm11.56-7.83c.13.47.22 1.1.28 1.9c.07.8.1 1.49.1 2.09L22 12c0 2.19-.16 3.8-.44 4.83c-.25.9-.83 1.48-1.73 1.73c-.47.13-1.33.22-2.65.28c-1.3.07-2.49.1-3.59.1L12 19c-4.19 0-6.8-.16-7.83-.44c-.9-.25-1.48-.83-1.73-1.73c-.13-.47-.22-1.1-.28-1.9c-.07-.8-.1-1.49-.1-2.09L2 12c0-2.19.16-3.8.44-4.83c.25-.9.83-1.48 1.73-1.73c.47-.13 1.33-.22 2.65-.28c1.3-.07 2.49-.1 3.59-.1L12 5c4.19 0 6.8.16 7.83.44c.9.25 1.48.83 1.73 1.73"
                        />
                      </svg>
                    </a>
                  )}
                </div>
              </div>
              <div class="p-4 text-left">
                <h3 class="text-base lg:text-xl font-medium lg:font-medium text-white/90 mb-1">
                  {speaker.name}
                </h3>
                <p class="hidden lg:block text-sm font-medium text-gradient mb-3">
                  {speaker.specialty}
                </p>
                <p class="text-base text-white/70 leading-snug">
                  {speaker.topic}
                </p>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </section>
</Container>

<style scoped>
  .speaker-card {
    cursor: default;
    transition: all 0.2s ease-in-out;
  }

  .speaker-card:hover {
  }

  .speaker-blur {
    filter: blur(8px);
    /* background: rgba(0, 0, 0, 0.301); */
    opacity: 0.6;
  }

  .speaker-blur:hover {
    filter: blur(8px);
    opacity: 0.6;
    transform: scale(1.02);
  }

  .speaker-clear {
    filter: blur(0px);
    opacity: 1;
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  .speaker-clear:hover {
    transform: scale(1.02);
    background: rgba(0, 0, 0, 0.301);
  }

  .speaker-image {
    /* background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); */
  }
</style>
