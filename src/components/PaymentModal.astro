<div
  id="payment-modal-backdrop"
  class="fixed inset-0 bg-black/70 backdrop-blur-sm z-40 hidden"
>
</div>

<dialog
  id="payment-modal-dialog"
  class="fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-50 m-0 p-0 max-w-lg w-[90%] rounded-2xl bg-slate-900 border border-blue-800/40 shadow-xl shadow-blue-900/20 text-white hidden"
>
  <div class="p-6 md:p-8">
    <div class="flex justify-between items-center mb-6">
      <h3 class="text-2xl font-bold text-gradient">Métodos de Pago</h3>
      <button
        id="modal-close-btn"
        class="text-white/50 hover:text-white transition-colors"
        aria-label="Cerrar modal"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-6 w-6"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <div class="space-y-6 text-white/80">
      <div class="bg-slate-800/50 p-4 rounded-lg border border-slate-700/50">
        <h4 class="font-semibold text-lg text-white/90 mb-2">
          Opción 1: Caja Sede Administrativa
        </h4>
        <p>
          Realiza tu pago directamente en la
          <strong>Caja Sede Administrativa UNAJMA</strong>.
        </p>
        <p class="text-sm text-white/60 mt-1">
          Dirección: Jr. Juan Francisco Ramos N° 380 – Andahuaylas
        </p>
      </div>

      <div class="bg-slate-800/50 p-4 rounded-lg border border-slate-700/50">
        <h4 class="font-semibold text-lg text-white/90 mb-2">
          Opción 2: Banco de la Nación
        </h4>
        <p>
          Deposita en cualquier
          <strong>Banco de la Nación o Agente</strong>
          a la siguiente cuenta:
        </p>
        <div class="mt-3 bg-slate-900/70 p-3 rounded-md text-center">
          <p class="text-sm text-white/60">Cta. Cte. UNAJMA</p>
          <p
            class="text-2xl md:text-3xl font-bold text-blue-300 tracking-wider my-1"
          >
            00182009784
          </p>
        </div>
      </div>
    </div>

    <p class="text-center text-sm text-white/60 mt-8 italic">
      Recuerda guardar tu voucher, lo necesitarás para completar tu registro.
    </p>
  </div>
</dialog>

<script>
  const backdrop = document.getElementById(
    "payment-modal-backdrop"
  ) as HTMLElement;
  const dialog = document.getElementById(
    "payment-modal-dialog"
  ) as HTMLDialogElement;
  const openButton = document.getElementById("open-payment-modal");
  const closeButton = document.getElementById("modal-close-btn");

  function openModal() {
    backdrop.classList.remove("hidden");
    dialog.classList.remove("hidden");
    dialog.showModal();
    document.body.style.overflow = "hidden";
  }

  function closeModal() {
    backdrop.classList.add("hidden");
    dialog.classList.add("hidden");
    dialog.close();
    document.body.style.overflow = "auto";
  }

  openButton?.addEventListener("click", openModal);
  closeButton?.addEventListener("click", closeModal);
  backdrop.addEventListener("click", closeModal);
</script>
